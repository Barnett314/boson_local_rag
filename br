#!/bin/bash
# Boson RAG System жҢҮд»ӨйӣҶ (v3.1 - зі»зөұжңҚеӢҷж•ҙеҗҲзүҲ)

BR_SCRIPT_PATH="$(readlink -f "$0")"
PROJECT_DIR="$(dirname "$BR_SCRIPT_PATH")"
BR_PORT="8900"
BR_URL="http://127.0.0.1:${BR_PORT}"

GREEN='\033[0;32m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

QUERY="${@:2}"

show_help() {
    echo -e "${CYAN}рҹӨ– Boson RAG System жҢҮд»ӨжҢҮеҚ—${NC}"
    echo "========================================="
    echo -e "  ${GREEN}br find <ж–Үеӯ—>${NC}   - иӘһж„Ҹжҗңе°Ӣ (дёҚйңҖеҠ еј•иҷҹ)"
    echo -e "  ${GREEN}br ask <е•ҸйЎҢ>${NC}    - AI ж №ж“ҡзӯҶиЁҳеӣһзӯ”"
    echo -e "  ${GREEN}br match <ж–Үеӯ—>${NC}  - зІҫзўәеӯ—дёІжҗңе°Ӣ (еӮізөұ grep)"
    echo -e "  ${GREEN}br index${NC}         - жүӢеӢ•е»әз«Ӣ/жӣҙж–°зӯҶиЁҳзҙўеј•"
    echo -e "  ${GREEN}br clean${NC}         - жүӢеӢ•жё…йҷӨжҗңе°Ӣеҝ«еҸ–"
    echo -e "  ${GREEN}br status${NC}        - жӘўжҹҘиғҢжҷҜжңҚеӢҷеҒҘеә·зӢҖж…Ӣ"
    echo -e "  ${GREEN}br service start${NC} - е•ҹеӢ•еёёй§җжңҚеӢҷ (ијүе…ҘжЁЎеһӢиҮіиЁҳжҶ¶й«”)"
    echo -e "  ${GREEN}br service stop${NC}  - еҒңжӯўеёёй§җжңҚеӢҷ (е®Ңе…ЁйҮӢж”ҫиЁҳжҶ¶й«”)"
    echo -e "  ${GREEN}br help${NC}          - йЎҜзӨәжң¬иӘӘжҳҺйҒёе–®"
    echo "========================================="
}

case "$1" in
    status)
        RESP=$(curl -s --connect-timeout 2 "${BR_URL}/health" 2>/dev/null)
        [ $? -eq 0 ] && echo -e "${GREEN}вң… Boson RAG йҒӢиЎҢдёӯ${NC}\n$RESP" || echo -e "${RED}вқҢ жңҚеӢҷжңӘйҒӢиЎҢ (иЁҳжҶ¶й«”е·ІйҮӢж”ҫ)${NC}"
        exit 0 ;;
    service)
        OS="$(uname -s)"
        if [ "$2" == "start" ]; then
            if [ "$OS" == "Linux" ]; then
                sudo systemctl start boson-rag.service
                echo -e "${CYAN}рҹҡҖ зі»зөұжңҚеӢҷе·Іе•ҹеӢ•пјҢжЁЎеһӢијүе…ҘиЁҳжҶ¶й«”дёӯ${NC}"
            elif [ "$OS" == "Darwin" ]; then
                launchctl load -w "$HOME/Library/LaunchAgents/com.boson.rag.plist"
                echo -e "${CYAN}рҹҡҖ зі»зөұжңҚеӢҷе·Іе•ҹеӢ•пјҢжЁЎеһӢијүе…ҘиЁҳжҶ¶й«”дёӯ${NC}"
            fi
        elif [ "$2" == "stop" ]; then
            if [ "$OS" == "Linux" ]; then
                sudo systemctl stop boson-rag.service
                echo -e "${CYAN}рҹӣ‘ зі»зөұжңҚеӢҷе·ІеҒңжӯўпјҢиЁҳжҶ¶й«”е·Іе®Ңе…ЁйҮӢж”ҫ${NC}"
            elif [ "$OS" == "Darwin" ]; then
                launchctl unload -w "$HOME/Library/LaunchAgents/com.boson.rag.plist"
                echo -e "${CYAN}рҹӣ‘ зі»зөұжңҚеӢҷе·ІеҒңжӯўпјҢиЁҳжҶ¶й«”е·Іе®Ңе…ЁйҮӢж”ҫ${NC}"
            fi
        else
            echo -e "${RED}вҡ пёҸ з”Ёжі•: br service start | stop${NC}"
        fi
        exit 0 ;;
    clean)
        curl -s "${BR_URL}/cache/clear" && echo -e "${GREEN}рҹ§№ еҝ«еҸ–е·Іжё…йҷӨ${NC}"
        exit 0 ;;
    index)
        echo -e "${CYAN}рҹ§  й–Ӣе§Ӣе»әз«Ӣ/жӣҙж–°зҹҘиӯҳеә«зҙўеј•...${NC}"
        cd "$PROJECT_DIR"
        source .venv/bin/activate
        python build_index.py
        curl -s "${BR_URL}/cache/clear" > /dev/null
        echo -e "${GREEN}вң… зҙўеј•жӣҙж–°е®ҢжҲҗпјҒ${NC}"
        exit 0 ;;
    help)
        show_help
        exit 0 ;;
    find|ask|match)
        if [ -z "$QUERY" ]; then
            echo -e "${RED}вҡ пёҸ и«Ӣијёе…ҘиҰҒжҗңе°Ӣзҡ„е…§е®№пјҒ${NC}"
            show_help
            exit 1
        fi
        MODE_ARG="$1"
        [ "$MODE_ARG" == "find" ] && MODE="search"
        [ "$MODE_ARG" == "ask" ] && MODE="full"
        [ "$MODE_ARG" == "match" ] && MODE="grep" ;;
    *)
        show_help
        exit 0 ;;
esac

ENCODED_Q=$(python3 -c "import urllib.parse; print(urllib.parse.quote('''$QUERY'''))")
curl -s "${BR_URL}/search?q=${ENCODED_Q}&mode=${MODE}&top_k=5" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    if data.get('success'):
        print(f'гҖҗBoson RAGгҖ‘ {data.get(\"mode\")} жЁЎејҸ')
        print('в”Җ' * 40)
        if data.get('raw_output'):
            print(data['raw_output'].strip())
        else:
            print('вҡ пёҸ жүҫдёҚеҲ°зӣёй—ңе…§е®№гҖӮи«ӢзўәиӘҚзӯҶиЁҳиіҮж–ҷеӨҫдёӯжҳҜеҗҰеҢ…еҗ«жӯӨй—ңйҚөеӯ—пјҢжҲ–еҹ·иЎҢ br index йҮҚж–°е»әзҪ®зҙўеј•гҖӮ')
    else:
        print(f'вқҢ жҗңе°ӢйҢҜиӘӨ: {data.get(\"error\", \"жңӘзҹҘйҢҜиӘӨ\")}')
except Exception as e:
    print('вқҢ з„Ўжі•и§ЈжһҗдјәжңҚеҷЁеӣһжҮүпјҢи«ӢзўәиӘҚжңҚеӢҷжҳҜеҗҰе·Іе•ҹеӢ• (еҸҜијёе…Ҙ br service start)гҖӮ')
" 2>/dev/null
